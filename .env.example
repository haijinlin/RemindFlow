DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Used in links inside reminder emails.
APP_BASE_URL="http://localhost:3001"

# Resend email delivery.
RESEND_API_KEY=""
EMAIL_FROM="RemindFlow <notifications@example.com>"
REMIND_FLOW_NOTIFICATION_EMAIL=""

# Optional. If set, /api/reminders/daily-email requires:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Required in production. Protects the personal RemindFlow UI.
REMINDFLOW_APP_PASSWORD=""
AUTH_SECRET=""

# Local-only portfolio screenshot mode. Uses synthetic reminders and skips database reads on the home page.
# Never enable this in the production Vercel environment.
SCREENSHOT_MODE="false"
